{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill",
      "Read",
      "Edit",
      "MultiEdit",
      "Write",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git rev-parse:*)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(git blame:*)",

      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout -b:*)",
      "Bash(git switch -c:*)",
      "Bash(git push:*)",
      "Bash(git remote add:*)",

      "Bash(gh auth status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh api:*)",

      "Bash(command -v *)",
      "Bash(which *)",
      "Bash(test:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(grep:*)",
      "Bash(date:*)",
      "Bash(mkdir -p:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm -f .git/COMMIT_EDITMSG)",

      "Bash(uv:*)",
      "Bash(poetry:*)",
      "Bash(python:*)",

      "Glob",
      "Task",

      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      
      "Bash(git remote set-url:*)",
      "Bash(git remote remove:*)",
      "Bash(git remote rm:*)",
      "Bash(git remote rename:*)",
      "Bash(git tag:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git rebase -i:*)",
      "Bash(git rebase --interactive:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git revert:*)",
      "Bash(git rm:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git checkout -- *)",
      "Bash(git restore --source:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch --delete --force:*)",
      "Bash(git update-ref -d:*)",
      "Bash(git commit --amend:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git config --global:*)",
      "Bash(git config --system:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --mirror:*)",
      "Bash(git push --delete:*)",

      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh auth refresh:*)",

      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Read(**/*.key)",

      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -fr /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -fr ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf --no-preserve-root*)",
      "Bash(chmod 777 /*)",
      "Bash(chown -R:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=*)",
      "Bash(:(){ :|:& };:)"
    ]
  }
}
